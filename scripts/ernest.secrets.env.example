# cp scripts/ernest.secrets.env.example ~/ernest.secrets.env → fill → bash scripts/deploy-ernest.sh --secrets ~/ernest.secrets.env

# --- VPS: pick ONE ---
# A) Easiest — any provider, just IP + root password from their email:
VPS_IP=
VPS_PASSWORD=

# B) Auto DigitalOcean (signup via Google/GitHub — usually less hassle than Hetzner):
# DIGITALOCEAN_TOKEN=

# --- required: model (Anthropic direct) ---
ANTHROPIC_API_KEY=sk-ant-

# --- required: Composio (HubSpot, Outlook, Calendar, Slack-as-app, etc.) ---
COMPOSIO_API_KEY=ck_

# --- required: Telegram gateway (CEO chat) ---
# Create via @BotFather → /newbot → copy token. CEO user ID via @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_ALLOWED_USERS=123456789
# optional: chat ID for briefs/cron delivery (defaults to CEO DM)
# TELEGRAM_HOME_CHANNEL=

# --- optional: Railway CLI on VPS (Hostinger / headless deploy) ---
# Account token: railway.app/account/tokens → RAILWAY_API_TOKEN (whoami, create/link projects)
# Project token: Project → Settings → Tokens → RAILWAY_TOKEN (railway up / deploy)
# RAILWAY_API_TOKEN=
# RAILWAY_TOKEN=

# --- optional: Slack gateway (CEO can also connect Slack as a Composio app later) ---
# SLACK_BOT_TOKEN=xoxb-
# SLACK_APP_TOKEN=xapp-
# SLACK_ALLOWED_USERS=U
# SLACK_HOME_CHANNEL=C
